<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OFFPOST Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0a0a0a;
      color: #f0ece4;
      font-family: 'Roboto', sans-serif;
      padding: 2rem;
      min-height: 100vh;
    }
    h1 {
      font-family: 'Oswald', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 0.15em;
      margin-bottom: 2rem;
    }
    .album-list {
      max-width: 700px;
    }
    .album-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .album-arrows {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
    .album-arrows button {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.3);
      color: #f0ece4;
      font-family: 'Oswald', sans-serif;
      font-size: 0.8rem;
      padding: 0.2rem 0.5rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .album-arrows button:hover { background: rgba(255,255,255,0.1); }
    .album-info { flex: 1; }
    .album-title-input {
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(255,255,255,0.15);
      color: #f0ece4;
      font-family: 'Oswald', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.1em;
      padding: 0.3rem 0;
      width: 100%;
      max-width: 300px;
      outline: none;
    }
    .album-title-input:focus { border-bottom-color: #fff; }
    .album-meta {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.4);
      margin-top: 0.3rem;
      letter-spacing: 0.05em;
    }
    .show-title-label {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.6);
      display: flex;
      align-items: center;
      gap: 0.4rem;
      cursor: pointer;
      white-space: nowrap;
    }
    .show-title-label input { cursor: pointer; }
    .btn-delete {
      background: transparent;
      border: 1px solid rgba(255,100,100,0.4);
      color: rgba(255,100,100,0.7);
      font-family: 'Oswald', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      padding: 0.4rem 0.8rem;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }
    .btn-delete:hover {
      background: rgba(255,100,100,0.15);
      border-color: rgba(255,100,100,0.7);
    }
    .upload-section {
      margin-top: 3rem;
      max-width: 700px;
      padding: 2rem;
      border: 1px solid rgba(255,255,255,0.1);
    }
    .upload-section h2 {
      font-family: 'Oswald', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 0.15em;
      margin-bottom: 1.5rem;
    }
    .upload-field {
      margin-bottom: 1rem;
    }
    .upload-field label {
      display: block;
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.6);
      margin-bottom: 0.4rem;
      text-transform: uppercase;
    }
    .upload-field input[type="text"] {
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      color: #f0ece4;
      font-family: 'Oswald', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.1em;
      padding: 0.5rem 0;
      width: 100%;
      max-width: 300px;
      outline: none;
    }
    .upload-field input[type="text"]:focus { border-bottom-color: #fff; }
    .upload-field input[type="file"] {
      color: rgba(255,255,255,0.6);
      font-size: 0.85rem;
    }
    .btn-upload {
      background: #fff;
      color: #000;
      border: none;
      padding: 0.8rem 2rem;
      font-family: 'Oswald', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 0.2em;
      cursor: pointer;
      transition: opacity 0.3s;
      margin-top: 0.5rem;
    }
    .btn-upload:hover { opacity: 0.8; }
    .btn-upload:disabled { opacity: 0.4; cursor: wait; }
    .upload-progress {
      margin-top: 1rem;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.5);
      display: none;
    }
    .empty-state {
      color: rgba(255,255,255,0.4);
      font-style: italic;
      padding: 2rem 0;
    }
  </style>
</head>
<body>
  <h1>PORTFOLIO ADMIN</h1>

  <div class="album-list">
    <% if (albums.length === 0) { %>
      <p class="empty-state">No albums yet. Upload one below.</p>
    <% } %>
    <% albums.forEach((album, i) => { %>
      <div class="album-row" data-id="<%= album.id %>">
        <div class="album-arrows">
          <button onclick="reorder('<%= album.id %>', 'up')" <%= i === 0 ? 'disabled' : '' %>>&uarr;</button>
          <button onclick="reorder('<%= album.id %>', 'down')" <%= i === albums.length - 1 ? 'disabled' : '' %>>&darr;</button>
        </div>
        <div class="album-info">
          <input class="album-title-input" type="text" value="<%= album.title %>" maxlength="30"
            placeholder="Album title..."
            onchange="updateAlbum('<%= album.id %>', { title: this.value })">
          <div class="album-meta"><%= album.photos.length %> photos &middot; <%= album.id %></div>
        </div>
        <label class="show-title-label">
          <input type="checkbox" <%= album.showTitle ? 'checked' : '' %>
            onchange="updateAlbum('<%= album.id %>', { showTitle: this.checked })">
          Show title
        </label>
        <button class="btn-delete" onclick="deleteAlbum('<%= album.id %>')">DELETE</button>
      </div>
    <% }) %>
  </div>

  <div class="upload-section">
    <h2>+ UPLOAD NEW ALBUM</h2>
    <form id="upload-form">
      <div class="upload-field">
        <label>Album ID (lowercase, hyphens only)</label>
        <input type="text" name="albumId" pattern="[a-z0-9-]+" required placeholder="e.g. hawaii-2024">
      </div>
      <div class="upload-field">
        <label>Photos</label>
        <p style="font-size: 0.8rem; color: rgba(255,255,255,0.4); margin-bottom: 0.6rem;">Upload a folder of photos. Accepts JPG, PNG, TIFF, or WebP. Photos will be sorted alphabetically — the first becomes the album cover.</p>
        <input type="file" name="photos" multiple accept="image/*" required webkitdirectory directory>
      </div>
      <button type="submit" class="btn-upload">UPLOAD</button>
    </form>
    <div class="upload-progress" id="upload-progress">Processing images...</div>
  </div>

  <script>
    async function reorder(albumId, direction) {
      await fetch('/admin/albums/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ albumId, direction })
      });
      location.reload();
    }

    async function updateAlbum(albumId, fields) {
      await fetch(`/admin/albums/${albumId}/update`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(fields)
      });
    }

    async function deleteAlbum(albumId) {
      if (!confirm(`Delete album "${albumId}" and all its photos?`)) return;
      await fetch(`/admin/albums/${albumId}`, { method: 'DELETE' });
      location.reload();
    }

    document.getElementById('upload-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const btn = form.querySelector('.btn-upload');
      const progress = document.getElementById('upload-progress');

      btn.disabled = true;
      progress.style.display = 'block';

      const formData = new FormData(form);
      try {
        const resp = await fetch('/admin/albums/upload', {
          method: 'POST',
          body: formData
        });
        const result = await resp.json();
        if (result.success) {
          location.reload();
        } else {
          alert(result.error || 'Upload failed.');
          btn.disabled = false;
          progress.style.display = 'none';
        }
      } catch (err) {
        alert('Upload failed: ' + err.message);
        btn.disabled = false;
        progress.style.display = 'none';
      }
    });
  </script>
</body>
</html>
