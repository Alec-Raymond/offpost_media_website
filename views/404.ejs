<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Not Found — OFFPOST</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0a0a0a;
      color: #f0ece4;
      font-family: 'Roboto', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      text-align: center;
    }
    h1 {
      font-family: 'Oswald', sans-serif;
      font-size: 2rem;
      letter-spacing: 0.15em;
      margin-bottom: 1rem;
    }
    p { color: rgba(255,255,255,0.5); margin-bottom: 2rem; }
    a {
      color: #f0ece4;
      text-decoration: none;
      font-family: 'Oswald', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 0.15em;
      border: 1px solid rgba(255,255,255,0.3);
      padding: 0.8rem 2rem;
      transition: background 0.3s;
    }
    a:hover { background: rgba(255,255,255,0.1); }
  </style>
</head>
<body>
  <div>
    <h1>404</h1>
    <p><%= message %></p>
    <a href="/portfolio">BACK TO PORTFOLIO</a>
  </div>
</body>
</html>
